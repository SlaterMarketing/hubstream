// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  ctaColor     String?  // Hex colour for buttons on event pages
  customDomain String?
  plan         String   @default("free") // "free" | "pro"
  createdAt    DateTime @default(now())

  users              User[]
  invites            Invite[]
  events             Event[]
  customFields       CustomField[]
  speakers           Speaker[]
  integrationSettings IntegrationSettings?
  subscription       Subscription?
}

model Invite {
  id        String   @id @default(cuid())
  orgId     String
  email     String
  role      String   @default("member") // "admin" | "member"
  token     String   @unique
  invitedById String
  expiresAt DateTime
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy    User          @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
}

model Speaker {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  bio         String?
  imageUrl    String?
  socialLinks Json?   // { twitter?, linkedin?, website? }
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  events       EventSpeaker[]
}

model Subscription {
  id                    String    @id @default(cuid())
  orgId                 String    @unique
  stripeCustomerId      String    @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  status                String
  interval              String?   // "month" | "year"
  currentPeriodEnd      DateTime?
  cancelAt              DateTime?
  createdAt             DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  orgId         String?   // Nullable until onboarding completes
  email         String
  emailVerified DateTime?
  name          String?
  image         String?
  role          String    @default("member") // "owner" | "admin" | "member"
  createdAt     DateTime  @default(now())

  organization   Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accounts       Account[]
  sessions       Session[]
  invitesSent    Invite[]      @relation("InvitedBy")

  @@unique([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type       String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id                 String   @id @default(cuid())
  orgId              String
  createdById        String
  title              String
  slug               String
  subtitle           String?
  description        Json?    // Tiptap JSON
  startsAt           DateTime
  durationMinutes    Int      @default(60)
  timezone           String   @default("UTC")
  meetLink           String?
  calendarEventId    String?
  status             String   @default("draft") // "draft" | "published" | "completed" | "cancelled"
  speakers           String?  // Legacy comma-separated; prefer eventSpeakers
  coverImageUrl      String?
  recordingUrl       String?
  media              Json?    // [{ type: "image"|"youtube", url, videoId? }]
  registrationFields Json?    // [{ key, label, type, required }] - email always required
  customFields       Json?    // Deprecated; use registrationFields
  createdAt          DateTime @default(now())

  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  registrations  Registration[]
  pageViews      PageView[]
  eventSpeakers  EventSpeaker[]

  @@unique([orgId, slug])
}

model EventSpeaker {
  id        String  @id @default(cuid())
  eventId   String
  speakerId String
  sortOrder Int     @default(0)

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speaker Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@unique([eventId, speakerId])
}

model Registration {
  id               String   @id @default(cuid())
  eventId          String
  email            String
  firstName        String?
  lastName         String?
  company         String?
  jobTitle        String?
  customFieldValues Json?
  hubspotContactId String?
  locale          String?
  cancelToken     String   @unique
  unsubscribed    Boolean  @default(false)
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  status          String   @default("confirmed") // "confirmed" | "cancelled"
  createdAt       DateTime @default(now())

  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  consentRecords  ConsentRecord[]
}

model ConsentRecord {
  id             String   @id @default(cuid())
  registrationId String
  consentType   String
  granted       Boolean
  ipAddress     String?
  grantedAt     DateTime  @default(now())

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model CustomField {
  id        String  @id @default(cuid())
  orgId     String
  label     String
  type      String  // "text" | "select" | "checkbox"
  required  Boolean @default(false)
  sortOrder Int     @default(0)
  options   Json?   // For select: ["Option 1", "Option 2"]

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model PageView {
  id          String   @id @default(cuid())
  eventId     String
  visitorHash String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  country     String?
  device      String?
  viewedAt    DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model IntegrationSettings {
  id                    String   @id @default(cuid())
  orgId                 String   @unique
  hubspotAccessToken    String?
  hubspotRefreshToken   String?
  hubspotExpiresAt      Int?
  hubspotPortalId      String?
  hubspotFieldMapping   Json?    // { "formFieldKey": "hubspotPropertyName" }
  createdAt             DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}
