// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  customDomain String?
  plan         String   @default("free") // "free" | "pro"
  createdAt    DateTime @default(now())

  users              User[]
  events             Event[]
  customFields       CustomField[]
  integrationSettings IntegrationSettings?
  subscription       Subscription?
}

model Subscription {
  id                    String    @id @default(cuid())
  orgId                 String    @unique
  stripeCustomerId      String    @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  status                String
  interval              String?   // "month" | "year"
  currentPeriodEnd      DateTime?
  cancelAt              DateTime?
  createdAt             DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  orgId         String?   // Nullable until onboarding completes
  email         String
  emailVerified DateTime?
  name          String?
  image         String?
  role          String    @default("member") // "owner" | "admin" | "member"
  createdAt     DateTime  @default(now())

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accounts     Account[]

  @@unique([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type       String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id               String   @id @default(cuid())
  orgId            String
  createdById      String
  title            String
  slug             String
  description      Json?    // Tiptap JSON
  startsAt         DateTime
  durationMinutes  Int      @default(60)
  timezone         String   @default("UTC")
  meetLink         String?
  calendarEventId  String?
  status           String   @default("draft") // "draft" | "published" | "completed" | "cancelled"
  speakers         String?
  coverImageUrl    String?
  recordingUrl     String?
  customFields     Json?    // References to CustomField ids for this event
  createdAt        DateTime @default(now())

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  registrations Registration[]
  pageViews      PageView[]

  @@unique([orgId, slug])
}

model Registration {
  id               String   @id @default(cuid())
  eventId          String
  email            String
  firstName        String?
  lastName         String?
  company         String?
  jobTitle        String?
  customFieldValues Json?
  hubspotContactId String?
  locale          String?
  cancelToken     String   @unique
  unsubscribed    Boolean  @default(false)
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  status          String   @default("confirmed") // "confirmed" | "cancelled"
  createdAt       DateTime @default(now())

  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  consentRecords  ConsentRecord[]
}

model ConsentRecord {
  id             String   @id @default(cuid())
  registrationId String
  consentType   String
  granted       Boolean
  ipAddress     String?
  grantedAt     DateTime  @default(now())

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model CustomField {
  id        String  @id @default(cuid())
  orgId     String
  label     String
  type      String  // "text" | "select" | "checkbox"
  required  Boolean @default(false)
  sortOrder Int     @default(0)
  options   Json?   // For select: ["Option 1", "Option 2"]

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model PageView {
  id          String   @id @default(cuid())
  eventId     String
  visitorHash String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  country     String?
  device      String?
  viewedAt    DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model IntegrationSettings {
  id                 String   @id @default(cuid())
  orgId              String   @unique
  hubspotAccessToken String?
  hubspotRefreshToken String?
  hubspotExpiresAt   Int?
  hubspotPortalId    String?
  createdAt          DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}
