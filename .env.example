# Database
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (for login + Calendar API)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# HubSpot
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_ANNUAL_PRICE_ID=""

# Resend (use your verified domain, e.g. noreply@mail.hubstream.app)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="HubStream <noreply@mail.hubstream.app>"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
# Use "eu" for EU jurisdiction buckets (required when bucket shows "| EU" in dashboard)
R2_JURISDICTION="eu"

# Cron
CRON_SECRET=""

# Super admins (comma-separated emails, e.g. admin@example.com,other@example.com)
SUPER_ADMIN_EMAILS=""
